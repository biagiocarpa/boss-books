# Supabase (compilare con i valori del progetto Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email di avviso richieste (Resend) — opzionale: se assenti, l'invio viene saltato senza errori
RESEND_API_KEY=
EMAIL_FROM=
BOSS_NOTIFY_EMAIL=

# Link al negozio eBay mostrato in vetrina (opzionale: default nel codice)
NEXT_PUBLIC_EBAY_STORE_URL=https://www.ebay.it/usr/trovalibro.mo
